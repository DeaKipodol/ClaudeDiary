{
  "name": "claudediary",
  "version": "1.0.0",
  "description": "A local diary for your Claude Code conversations.",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --out-path dist",
    "build:mac": "pkg . --targets node18-macos-arm64 --out-path dist && xattr -cr dist/",
    "build:mac-intel": "pkg . --targets node18-macos-x64 --out-path dist",
    "build:win": "pkg . --targets node18-win-x64 --out-path dist",
    "build:linux": "pkg . --targets node18-linux-x64 --out-path dist"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64",
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2"
  }
}
